<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="INFO">

    <Properties>
        <Property name="commonBasePath">./logs</Property>
    </Properties>

    <Appenders>
        <Console name="Console log" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <RollingFile name="XML File" fileName="${commonBasePath}/automation.log"
                     filePattern="${commonBasePath}/automation-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
            <SizeBasedTriggeringPolicy size="500000"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="Info">
            <!-- <AppenderRef ref="Console log"/> -->
            <AppenderRef ref="XML File"/>
        </Root>
    </Loggers>

</Configuration>
